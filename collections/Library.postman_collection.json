					"listen": "test",
					"script": {
						"exec": [
							"const response_body = pm.response.json()",
							"const schema = {",
							"  \"type\": \"array\",",
							"  \"items\": [",
							"    {",
							"      \"type\": \"object\",",
							"      \"properties\": {",
							"        \"book_name\": {",
							"          \"type\": \"string\"",
							"        },",
							"        \"isbn\": {",
							"          \"type\": \"string\"",
							"        },",
							"        \"aisle\": {",
							"          \"type\": \"string\"",
							"        },",
							"        \"author\": {",
							"          \"type\": \"string\"",
							"        }",
							"      },",
							"      \"required\": [",
							"        \"book_name\",",
							"        \"isbn\",",
							"        \"aisle\",",
							"        \"author\"",
							"      ]",
							"    }",
							"  ]",
							"};",
							"console.log(response_body)",
							"pm.test(\"Validation status code for get book is 200\",function(){",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"// validate book details",
							"pm.test(\"Validation response body , book name\",function(){",
							"    pm.expect(response_body[0].book_name).to.eql(pm.collectionVariables.get(\"book_name\"));",
							"    pm.expect(response_body[0].isbn).to.eql(pm.collectionVariables.get(\"isbn\"));",
							"});",
							"",
							"",
							"// validation response schema",
							"pm.test(\"validation response schema\",function(){",
							"    pm.response.to.have.jsonSchema(schema);",
							"})",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
