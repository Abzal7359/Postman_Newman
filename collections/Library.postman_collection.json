	"item": [
		{
			"name": "ADDbook",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// validate the status code here",
							"const responseJson = pm.response.json();",
							"var id= pm.collectionVariables.get(\"isbn\")",
							"const schema = {",
							"  \"type\": \"object\",",
							"  \"properties\": {",
							"    \"Msg\": {",
							"      \"type\": \"string\"",
							"    },",
							"    \"ID\": {",
							"      \"type\": \"string\"",
							"    }",
							"  },",
							"  \"required\": [",
							"    \"Msg\",",
							"    \"ID\"",
							"  ]",
							"};",
							"",
							"// set response_id in collection varible",
							"pm.collectionVariables.set(\"response_book_id\",responseJson.ID);",
							"",
							"",
							"pm.test(\"Validation status code is 200\",function(){",
							"    pm.response.to.have.status(200);",
							"    pm.expect(responseJson).to.have.property(\"Msg\");",
							"    pm.expect(responseJson.Msg).to.eql(\"successfully added\");",
							"    const request_body = JSON.parse(pm.request.body.raw);",
							"    pm.expect(responseJson.ID).to.eql(id+request_body.aisle);",
							"});",
							"",
							"// validation of headers and response time ",
							"pm.test(\"Validate headers and respponse time\",function(){",
							"    pm.response.to.have.header(\"Content-Type\");",
							"    pm.expect( pm.response.headers.get(\"Content-Type\")).to.eql(\"application/json;charset=UTF-8\");",
							"    pm.expect(pm.response.responseTime).to.below(1200);",
							"    pm.expect(pm.response.text()).to.include(\"successfully added\")",
							"",
							"})",
							"",
							"",
							"// validation response schema",
							"pm.test(\"validation response schema\",function(){",
							"    pm.response.to.have.jsonSchema(schema);",
							"})"
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"//dynamic book name , isbn , aisle  generating ",
							"var tme = pm.variables.replaceIn('{{$timestamp}}')",
							"console.log('API Automation Book Name' + tme)",
							"pm.collectionVariables.set(\"book_name\",'API Automation Book Name' + tme)",
							"pm.collectionVariables.set(\"isbn\",tme)",
							"var auth_name =pm.iterationData.get(\"Author_name\") ",
							"pm.collectionVariables.set(\"author_name\",auth_name)",
							"console.log(\"author_name\")",
							"",
							"",
							"",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"{{book_name}}\",\n    \"isbn\": \"{{isbn}}\",\n    \"aisle\": \"227\",\n    \"author\": \"{{author_name}}\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/Library/Addbook.php",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"Library",
						"Addbook.php"
					]
				}
			},
			"response": []
		},
